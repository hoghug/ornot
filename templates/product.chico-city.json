            "mobile_image_aspect_ratio": 1,
            "heading_tag": "automatic"
          }
        },
        "image_nCBHTr": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/ferris.jpg",
            "image_width": 100,
            "image_shape": "normal",
            "title": "FERRIS PLOCK (PRO ARTIST)",
            "heading_font_size": "heading-small",
            "text": "<p>Ferris is a San Francisco artist known for layered, character-driven work that shows up everywhere from your local coffee shop to SFMOMA. Based in the Richmond District, he often collaborates with his wife, Kelly Tunstall.</p>",
            "text_font_size": "body-medium",
            "button_text": "",
            "button_url": "",
            "button_type": "btn--primary",
            "button_size": "",
            "button_style": "btn--solid",
            "show_arrow": false,
            "image_aspect_ratio": 1,
            "mobile_image_aspect_ratio": 1,
            "heading_tag": "automatic"
          }
        },
        "image_LgjCMC": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/27U6340.jpg",
            "image_width": 100,
            "image_shape": "normal",
            "title": "MATT QUANN (CHIEF BIKE RIDER @ORNOT )",
            "heading_font_size": "heading-small",
            "text": "<p>The founder of Ornot, Matt, grew up skating and riding before starting the brand in a Lower Haight Victorian in 2013. It was built on the idea that good gear doesn’t need big logos, just thoughtful design and responsible production.</p>",
            "text_font_size": "body-medium",
            "button_text": "",
            "button_url": "",
            "button_type": "btn--primary",
            "button_size": "",
            "button_style": "btn--solid",
            "show_arrow": false,
