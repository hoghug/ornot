    "section_columns_fcn6BT": {
      "type": "section-columns",
      "blocks": {
        "image_rqRbPM": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/chico-brenes-web.jpg",
            "image_width": 100,
            "image_shape": "normal",
            "title": "CHICO BRENES (PRO SKATER)",
            "heading_font_size": "heading-small",
            "text": "<p>Chico is a San Francisco–based pro skateboarder who came up in the EMB era, known for the nollie heel flip, aka the Chico flip. Born in Nicaragua and raised in the Bay, he now splits his time between skating, riding, and good coffee.</p>",
            "text_font_size": "body-medium",
            "button_text": "",
            "button_url": "",
            "button_type": "btn--primary",
            "button_size": "",
            "button_style": "btn--solid",
