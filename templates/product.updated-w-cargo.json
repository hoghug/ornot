            "image_width": 100,
            "image_shape": "normal",
            "title": "durable + breathable straps",
            "heading_font_size": "heading-small",
            "text": "<p>Redesigned bib straps feature a more durable construction and subtle channeling that reduces fabric contact and promotes airflow, helping regulate temperature and moisture during long rides in the heat.</p>",
            "text_font_size": "body-medium",
