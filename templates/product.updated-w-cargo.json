            "image_width": 100,
            "image_shape": "normal",
            "title": "updated cargo pockets",
            "heading_font_size": "heading-small",
            "text": "<p>Updated pockets use the same durable fabric as the bibs themselves, along with a low-profile bonded hem. This translates to pockets that are nearly invisible when empty and far more resistant to snags.</p>",
            "text_font_size": "body-medium",
