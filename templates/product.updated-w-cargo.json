          "settings": {
            "image": "shopify://shop_images/mens-cargo-bib-chamoix-2026.jpg",
            "image_width": 100,
            "image_shape": "normal",
            "title": "dense endurance chamois",
            "heading_font_size": "heading-small",
            "text": "<p>Our Women's endurance chamois maintains the shape riders love, now paired with increased stretch in the bib fabric so the pad stays stable while the shorts move naturally with your body, improving comfort on long rides.</p>",
            "text_font_size": "body-medium",
            "button_text": "",
