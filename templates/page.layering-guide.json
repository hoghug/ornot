        "text_LFLBf3": {
          "type": "text",
          "settings": {
            "subheading": "/ / / / / / / / / / / /",
            "title": "1% For The Planet",
            "heading_font_size": "heading-large",
            "text": "<p>Every purchase you make with us sends 1% to nonprofits protecting clean air, clean water, and the places we ride. Through 1% for the Planet, your support goes directly to the organizations making the most impact.</p><p>For us, 1% of revenue is a real commitment. We’re a small, independent company without outside investors, but we believe giving back is part of doing business the right way. From recycled fabrics to California manufacturing to compostable packaging, responsibility guides everything we do.</p><p>By choosing Ornot, you’re joining a global movement where small choices create big change. Together we can protect the planet — and keep it a place worth riding.</p>",
            "text_font_size": "body-small",
            "button_text": "why one percent?",
            "button_url": "shopify://pages/1-for-the-planet",
